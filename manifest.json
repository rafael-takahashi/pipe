{
  "manifest_version": 3,
  "name": "pipe",
  "version": "1.0",
  "icons": {
    "32": "icons/pipe-logo.svg",
    "64": "icons/pipe-logo.svg"
  },

  "permissions": ["storage"],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "pipe"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "@addon-example",
      "strict_min_version": "58.0"
    }
  }
}
